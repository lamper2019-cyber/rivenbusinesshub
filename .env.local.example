# Google Sheets API credentials
# 1. Go to https://console.cloud.google.com
# 2. Create a project (or use existing)
# 3. Enable "Google Sheets API"
# 4. Create a Service Account under Credentials
# 5. Download the JSON key file
# 6. Share your "RIVEN Master" Google Sheet with the service account email
# 7. Copy the values below from your JSON key file

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-from-the-url

# The sheet ID is the long string in the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_SHEET_ID/edit
